# Paste these into the Railway app service Variables tab.
# Do not commit real secret values.

SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=False
USE_SQLITE=False

# Railway provides RAILWAY_PUBLIC_DOMAIN automatically after you generate a domain.
APP_BASE_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
ALLOWED_HOSTS=${{RAILWAY_PUBLIC_DOMAIN}}
CSRF_TRUSTED_ORIGINS=https://${{RAILWAY_PUBLIC_DOMAIN}}

# Add a Railway PostgreSQL service named "Postgres", then reference its URL here.
DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_SSLMODE=require

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# M-Pesa
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}/payments/mpesa/callback/
MPESA_ENVIRONMENT=sandbox

# Email via Resend
EMAIL_DELIVERY_BACKEND=resend
EMAIL_SEND_ASYNC=True
DEFAULT_FROM_EMAIL=orders@your-verified-domain.com
DEFAULT_FROM_NAME=Savanna Scoops
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails

# SMTP fallback values. Usually unused when EMAIL_DELIVERY_BACKEND=resend.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
