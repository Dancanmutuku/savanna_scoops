# Django production settings when the app is served behind Cloudflare.
# Copy these values into your production environment, not into Git with real secrets.

SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=False
USE_SQLITE=False
APP_BASE_URL=https://savannascoops.example.com

# Replace these with your Cloudflare-hosted domain names.
ALLOWED_HOSTS=savannascoops.example.com,www.savannascoops.example.com
CSRF_TRUSTED_ORIGINS=https://savannascoops.example.com,https://www.savannascoops.example.com

# Use a real production Postgres database. Do not use SQLite for production hosting.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_SSLMODE=require

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# M-Pesa
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://savannascoops.example.com/payments/mpesa/callback/
MPESA_ENVIRONMENT=sandbox

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com
DEFAULT_FROM_NAME=Savanna Scoops
EMAIL_DELIVERY_BACKEND=resend
EMAIL_SEND_ASYNC=True
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
